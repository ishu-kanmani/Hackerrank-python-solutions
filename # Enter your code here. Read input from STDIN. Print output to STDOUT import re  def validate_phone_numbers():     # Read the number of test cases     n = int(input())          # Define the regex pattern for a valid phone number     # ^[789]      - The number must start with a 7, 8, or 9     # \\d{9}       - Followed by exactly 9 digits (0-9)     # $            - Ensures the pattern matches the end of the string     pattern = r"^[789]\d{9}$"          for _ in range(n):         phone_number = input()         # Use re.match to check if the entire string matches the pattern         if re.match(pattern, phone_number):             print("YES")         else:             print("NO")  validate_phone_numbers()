import re
import email.utils

# Read the number of email addresses
n = int(input())

# Regex Pattern breakdown:
# ^[a-zA-Z]       : Starts with an alphabetical character.
# [a-zA-Z0-9._-]+ : One or more alphanumeric, '-', '.', or '_' characters.
# @               : Literal '@' symbol.
# [a-zA-Z]+       : Domain contains only alphabetical characters.
# \.              : Literal dot.
# [a-zA-Z]{1,3}$  : Extension contains only alphabetical characters (1-3 long).
pattern = r'^[a-zA-Z][a-zA-Z0-9._-]+@[a-zA-Z]+\.[a-zA-Z]{1,3}$'

for _ in range(n):
    # Read each line containing 'name <email>'
    line = input()
    
    # parseaddr returns a tuple: (name, email_address)
    name, addr = email.utils.parseaddr(line)
    
    # Check if the extracted email address matches our criteria
    if re.match(pattern, addr):
        # formataddr recreates the 'name <email>' string in a standard way
        print(email.utils.formataddr((name, addr)))
