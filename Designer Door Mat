# Enter your code here. Read input from STDIN. Print output to STDOUT# Read input values N and M
N, M = map(int, input().split())

# Top half of the mat
for i in range(1, N // 2 + 1):
    pattern = ".|." * (2 * i - 1)
    print(pattern.center(M, "-"))

# Middle 'WELCOME' message
print("WELCOME".center(M, "-"))

# Bottom half of the mat (reverse of the top half)
for i in range(N // 2, 0, -1):
    pattern = ".|." * (2 * i - 1)
    print(pattern.center(M, "-"))
