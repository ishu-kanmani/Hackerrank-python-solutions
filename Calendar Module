import calendar

# Read input as space-separated integers
month, day, year = map(int, input().split())

# Get the day index using calendar.weekday(year, month, day)
# Note: The function takes year, month, day in that order
day_index = calendar.weekday(year, month, day)

# Get the day name string from the index and convert to uppercase
day_of_week = calendar.day_name[day_index].upper()

# Print the result
print(day_of_week)
