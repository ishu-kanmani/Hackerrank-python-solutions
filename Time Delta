from datetime import datetime

def time_delta(t1, t2):
    # Define the required format string for strptime
    fmt = '%a %d %b %Y %H:%M:%S %z'
    
    # Convert the input strings to datetime objects
    time1 = datetime.strptime(t1, fmt)
    time2 = datetime.strptime(t2, fmt)
    
    # Calculate the absolute difference and return total seconds as an integer
    # The result of subtraction is a timedelta object
    # abs() handles the order of t1 and t2
    # total_seconds() method is used to get the difference in seconds
    return str(int(abs((time1 - time2).total_seconds())))

