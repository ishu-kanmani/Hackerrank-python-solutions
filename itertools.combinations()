from itertools import combinations

# Read input from STDIN
s, k = input().split()

# Sort the string to ensure lexicographical order of combinations
s = sorted(s)
k = int(k)

# Iterate from combination length 1 up to k
for length in range(1, k + 1):
    # Generate combinations for the current length
    for comb in combinations(s, length):
        # Join the characters in each combination and print
        print("".join(comb))
