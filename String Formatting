def print_formatted(number):
    # Calculate the width required for padding based on the length of the binary representation of 'number'
    width = len(f"{number:b}")
    
    for i in range(1, number + 1):
        # Use f-strings for concise formatting
        # :width specifies the minimum field width for padding
        # d, o, X, b are format specifiers for decimal, octal, uppercase hexadecimal, and binary respectively
        print(f"{i:{width}d} {i:{width}o} {i:{width}X} {i:{width}b}")

